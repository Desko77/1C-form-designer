  <!-- ====== Event Handlers ====== -->
  <Events>
    <Event>
      <Name>ПриСозданииНаСервере</Name>
      <Handler>ПриСозданииНаСервере</Handler>
    </Event>
    <Event>
      <Name>ПриОткрытии</Name>
      <Handler>ПриОткрытии</Handler>
    </Event>
    <Event>
      <Name>ПередЗаписью</Name>
