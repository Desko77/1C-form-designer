    <Command>
      <Name>ПровестиИЗакрыть</Name>
      <Id>701</Id>
      <Title>Провести и закрыть</Title>
      <ToolTip>Провести документ и закрыть форму</ToolTip>
      <Action>ПровестиИЗакрыть</Action>
    </Command>
    <Command>
      <Name>Печать</Name>
      <Id>702</Id>
      <Title>Печать</Title>
      <Action>Печать</Action>
    </Command>
    <Command>
      <Name>ТоварыДобавитьСтроку</Name>
      <Id>703</Id>
      <Title>Добавить строку</Title>
      <Action>ТоварыДобавитьСтроку</Action>
    </Command>
    <Command>
      <Name>ТоварыУдалитьСтроку</Name>
      <Id>704</Id>
      <Title>Удалить строку</Title>
      <Action>ТоварыУдалитьСтроку</Action>
    </Command>
    <Command>
      <Name>ПодборТоваров</Name>
      <Id>705</Id>
      <Title>Подбор товаров</Title>
      <ToolTip>Открыть подбор товаров</ToolTip>
      <Action>ПодборТоваров</Action>
    </Command>
    <Command>
      <Name>РассчитатьСкидки</Name>
      <Id>706</Id>
      <Title>Рассчитать скидки</Title>
      <Action>РассчитатьСкидки</Action>
    </Command>
    <Command>
      <Name>ПечатьСчет</Name>
      <Id>707</Id>
      <Title>Счет на оплату</Title>
      <Action>ПечатьСчет</Action>
    </Command>
    <Command>
      <Name>ПечатьНакладная</Name>
      <Id>708</Id>
      <Title>Товарная накладная</Title>
      <Action>ПечатьНакладная</Action>
    </Command>
    <Command>
      <Name>ПечатьСчетФактура</Name>
      <Id>709</Id>
      <Title>Счет-фактура</Title>
      <Action>ПечатьСчетФактура</Action>
