<?xml version="1.0" encoding="UTF-8"?>
<ManagedForm xmlns="http://v8.1c.ru/8.3/xcf/managed"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:xs="http://www.w3.org/2001/XMLSchema"
             xmlns:xr="http://v8.1c.ru/8.3/xcf/readable">
  <AutoTitle>true</AutoTitle>
  <Title>Реализация товаров и услуг</Title>

  <!-- ====== Attributes ====== -->
  <Attributes>
    <Attribute>
      <Name>Объект</Name>
      <Id>0</Id>
      <ValueType>
        <Type>DocumentObject.РеализацияТоваровУслуг</Type>
      </ValueType>
      <SavedData>true</SavedData>
    </Attribute>
    <Attribute>
      <Name>ИтогоСумма</Name>
      <Id>1</Id>
      <ValueType>
        <Type xs:type="xs:string">Number</Type>
      </ValueType>
    </Attribute>
    <Attribute>
      <Name>ИтогоНДС</Name>
      <Id>2</Id>
      <ValueType>
        <Type xs:type="xs:string">Number</Type>
      </ValueType>
    </Attribute>
  </Attributes>

  <!-- ====== Elements ====== -->
  <Elements>
    <!-- Header fields -->
    <UsualGroup>
      <Name>ГруппаШапка</Name>
      <Id>100</Id>
      <Title>Шапка документа</Title>
      <Group>Horizontal</Group>
      <Representation>NormalSeparation</Representation>
      <Elements>
        <InputField>
          <Name>Номер</Name>
          <Id>101</Id>
          <Title>Номер</Title>
          <DataPath>Объект.Номер</DataPath>
          <Width>12</Width>
          <ReadOnly>true</ReadOnly>
        </InputField>
        <InputField>
          <Name>Дата</Name>
          <Id>102</Id>
          <Title>Дата</Title>
          <DataPath>Объект.Дата</DataPath>
          <Width>12</Width>
        </InputField>
        <InputField>
          <Name>Контрагент</Name>
          <Id>103</Id>
          <Title>Контрагент</Title>
          <DataPath>Объект.Контрагент</DataPath>
          <Width>30</Width>
          <HorizontalStretch>true</HorizontalStretch>
          <ChoiceButton>true</ChoiceButton>
        </InputField>
        <InputField>
          <Name>Склад</Name>
          <Id>104</Id>
          <Title>Склад</Title>
          <DataPath>Объект.Склад</DataPath>
          <Width>20</Width>
          <ChoiceButton>true</ChoiceButton>
        </InputField>
      </Elements>
    </UsualGroup>

    <!-- Main table: Товары -->
    <Table>
      <Name>Товары</Name>
      <Id>200</Id>
      <Title>Товары</Title>
      <DataPath>Объект.Товары</DataPath>
      <HorizontalStretch>true</HorizontalStretch>
      <VerticalStretch>true</VerticalStretch>
      <Height>12</Height>
      <CommandBar>
        <Name>ТоварыКоманднаяПанель</Name>
        <Id>201</Id>
        <Elements>
          <Button>
            <Name>ТоварыДобавить</Name>
            <Id>202</Id>
            <Title>Добавить</Title>
            <CommandName>ТоварыДобавитьСтроку</CommandName>
          </Button>
          <Button>
            <Name>ТоварыКопировать</Name>
            <Id>203</Id>
            <Title>Скопировать</Title>
            <CommandName>ТоварыКопироватьСтроку</CommandName>
          </Button>
          <Button>
            <Name>ТоварыУдалить</Name>
            <Id>204</Id>
            <Title>Удалить</Title>
            <CommandName>ТоварыУдалитьСтроку</CommandName>
          </Button>
          <Button>
            <Name>ТоварыВверх</Name>
            <Id>205</Id>
            <Title>Переместить вверх</Title>
            <CommandName>ТоварыПереместитьВверх</CommandName>
          </Button>
          <Button>
            <Name>ТоварыВниз</Name>
            <Id>206</Id>
            <Title>Переместить вниз</Title>
            <CommandName>ТоварыПереместитьВниз</CommandName>
          </Button>
          <Button>
            <Name>ТоварыПодбор</Name>
            <Id>207</Id>
            <Title>Подбор</Title>
            <CommandName>ПодборТоваров</CommandName>
          </Button>
          <Button>
            <Name>ТоварыЗаполнитьЦены</Name>
            <Id>208</Id>
            <Title>Заполнить цены</Title>
            <CommandName>ЗаполнитьЦены</CommandName>
          </Button>
        </Elements>
      </CommandBar>
      <Columns>
        <InputField>
          <Name>ТоварыНомерСтроки</Name>
          <Id>210</Id>
          <Title>N</Title>
          <DataPath>Объект.Товары.НомерСтроки</DataPath>
          <Width>4</Width>
          <ReadOnly>true</ReadOnly>
        </InputField>
        <InputField>
          <Name>ТоварыНоменклатура</Name>
          <Id>211</Id>
          <Title>Номенклатура</Title>
          <DataPath>Объект.Товары.Номенклатура</DataPath>
          <Width>30</Width>
          <ChoiceButton>true</ChoiceButton>
          <OpenButton>true</OpenButton>
        </InputField>
        <InputField>
          <Name>ТоварыХарактеристика</Name>
          <Id>212</Id>
          <Title>Характеристика</Title>
          <DataPath>Объект.Товары.Характеристика</DataPath>
          <Width>20</Width>
          <ChoiceButton>true</ChoiceButton>
        </InputField>
        <InputField>
          <Name>ТоварыКоличество</Name>
          <Id>213</Id>
          <Title>Количество</Title>
          <DataPath>Объект.Товары.Количество</DataPath>
          <Width>10</Width>
        </InputField>
        <InputField>
          <Name>ТоварыЕдиницаИзмерения</Name>
          <Id>214</Id>
          <Title>Ед.</Title>
          <DataPath>Объект.Товары.ЕдиницаИзмерения</DataPath>
          <Width>8</Width>
          <ChoiceButton>true</ChoiceButton>
        </InputField>
        <InputField>
          <Name>ТоварыЦена</Name>
          <Id>215</Id>
          <Title>Цена</Title>
          <DataPath>Объект.Товары.Цена</DataPath>
          <Width>12</Width>
        </InputField>
        <InputField>
          <Name>ТоварыСумма</Name>
          <Id>216</Id>
          <Title>Сумма</Title>
          <DataPath>Объект.Товары.Сумма</DataPath>
          <Width>12</Width>
          <ReadOnly>true</ReadOnly>
        </InputField>
        <InputField>
          <Name>ТоварыСтавкаНДС</Name>
          <Id>217</Id>
          <Title>% НДС</Title>
          <DataPath>Объект.Товары.СтавкаНДС</DataPath>
          <Width>8</Width>
        </InputField>
        <InputField>
          <Name>ТоварыСуммаНДС</Name>
          <Id>218</Id>
          <Title>НДС</Title>
          <DataPath>Объект.Товары.СуммаНДС</DataPath>
          <Width>12</Width>
          <ReadOnly>true</ReadOnly>
        </InputField>
        <InputField>
          <Name>ТоварыВсего</Name>
          <Id>219</Id>
          <Title>Всего</Title>
          <DataPath>Объект.Товары.Всего</DataPath>
          <Width>12</Width>
          <ReadOnly>true</ReadOnly>
        </InputField>
        <CheckBoxField>
          <Name>ТоварыАкцизныйТовар</Name>
          <Id>220</Id>
          <Title>Акциз</Title>
          <DataPath>Объект.Товары.АкцизныйТовар</DataPath>
        </CheckBoxField>
      </Columns>
    </Table>

    <!-- Totals row -->
    <UsualGroup>
      <Name>ГруппаИтоги</Name>
      <Id>300</Id>
      <Title>Итоги</Title>
      <Group>Horizontal</Group>
      <Representation>NormalSeparation</Representation>
      <Elements>
        <InputField>
          <Name>ИтогоСумма</Name>
          <Id>301</Id>
          <Title>Итого</Title>
          <DataPath>ИтогоСумма</DataPath>
          <Width>15</Width>
          <ReadOnly>true</ReadOnly>
        </InputField>
        <InputField>
          <Name>ИтогоНДС</Name>
          <Id>302</Id>
          <Title>В т.ч. НДС</Title>
          <DataPath>ИтогоНДС</DataPath>
          <Width>15</Width>
          <ReadOnly>true</ReadOnly>
        </InputField>
      </Elements>
    </UsualGroup>

    <!-- Bottom buttons -->
    <UsualGroup>
      <Name>ГруппаКнопки</Name>
      <Id>400</Id>
      <Title>Кнопки</Title>
      <Group>Horizontal</Group>
      <Representation>None</Representation>
      <Elements>
        <Button>
          <Name>КнопкаПровестиИЗакрыть</Name>
          <Id>401</Id>
          <Title>Провести и закрыть</Title>
          <CommandName>ПровестиИЗакрыть</CommandName>
          <Representation>Auto</Representation>
          <DefaultButton>true</DefaultButton>
        </Button>
        <Button>
          <Name>КнопкаПровести</Name>
          <Id>402</Id>
          <Title>Провести</Title>
          <CommandName>Провести</CommandName>
        </Button>
        <Button>
          <Name>КнопкаЗакрыть</Name>
          <Id>403</Id>
          <Title>Закрыть</Title>
          <CommandName>Закрыть</CommandName>
        </Button>
      </Elements>
    </UsualGroup>
  </Elements>

  <!-- ====== Commands ====== -->
  <Commands>
    <Command>
      <Name>ПровестиИЗакрыть</Name>
      <Id>500</Id>
      <Title>Провести и закрыть</Title>
      <Action>ПровестиИЗакрыть</Action>
    </Command>
    <Command>
      <Name>Провести</Name>
      <Id>501</Id>
      <Title>Провести</Title>
      <Action>Провести</Action>
    </Command>
    <Command>
      <Name>Закрыть</Name>
      <Id>502</Id>
      <Title>Закрыть</Title>
      <Action>Закрыть</Action>
    </Command>
    <Command>
      <Name>ТоварыДобавитьСтроку</Name>
      <Id>503</Id>
      <Title>Добавить</Title>
      <Action>ТоварыДобавитьСтроку</Action>
    </Command>
    <Command>
      <Name>ТоварыКопироватьСтроку</Name>
      <Id>504</Id>
      <Title>Скопировать</Title>
      <Action>ТоварыКопироватьСтроку</Action>
    </Command>
    <Command>
      <Name>ТоварыУдалитьСтроку</Name>
      <Id>505</Id>
      <Title>Удалить</Title>
      <Action>ТоварыУдалитьСтроку</Action>
    </Command>
    <Command>
      <Name>ТоварыПереместитьВверх</Name>
      <Id>506</Id>
      <Title>Переместить вверх</Title>
      <Action>ТоварыПереместитьВверх</Action>
    </Command>
    <Command>
      <Name>ТоварыПереместитьВниз</Name>
      <Id>507</Id>
      <Title>Переместить вниз</Title>
      <Action>ТоварыПереместитьВниз</Action>
    </Command>
    <Command>
      <Name>ПодборТоваров</Name>
      <Id>508</Id>
      <Title>Подбор</Title>
      <ToolTip>Открыть подбор товаров</ToolTip>
      <Action>ПодборТоваров</Action>
    </Command>
    <Command>
      <Name>ЗаполнитьЦены</Name>
      <Id>509</Id>
      <Title>Заполнить цены</Title>
      <ToolTip>Заполнить цены по типу цен контрагента</ToolTip>
      <Action>ЗаполнитьЦены</Action>
    </Command>
  </Commands>
</ManagedForm>
