<?xml version="1.0" encoding="UTF-8"?>
<ManagedForm xmlns="http://v8.1c.ru/8.3/xcf/managed"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:xs="http://www.w3.org/2001/XMLSchema"
             xmlns:xr="http://v8.1c.ru/8.3/xcf/readable">
  <AutoTitle>true</AutoTitle>
  <Title>Простая форма</Title>
  <Attributes>
    <Attribute>
      <Name>Объект</Name>
      <Id>0</Id>
      <ValueType>
        <Type>CatalogObject.Контрагенты</Type>
      </ValueType>
      <SavedData>true</SavedData>
    </Attribute>
    <Attribute>
      <Name>ДатаДокумента</Name>
      <Id>1</Id>
      <ValueType>
        <Type xs:type="xs:string">Date</Type>
      </ValueType>
    </Attribute>
  </Attributes>
  <Elements>
    <UsualGroup>
      <Name>ГруппаОсновная</Name>
      <Id>100</Id>
      <Title>Основная информация</Title>
      <Group>Vertical</Group>
      <Representation>NormalSeparation</Representation>
      <Elements>
        <InputField>
          <Name>Наименование</Name>
          <Id>101</Id>
          <Title>Наименование</Title>
          <DataPath>Объект.Наименование</DataPath>
          <Width>40</Width>
          <HorizontalStretch>true</HorizontalStretch>
        </InputField>
        <InputField>
          <Name>Код</Name>
          <Id>102</Id>
          <Title>Код</Title>
          <DataPath>Объект.Код</DataPath>
          <Width>15</Width>
          <ReadOnly>true</ReadOnly>
        </InputField>
        <InputField>
          <Name>ИНН</Name>
          <Id>103</Id>
          <Title>ИНН</Title>
          <DataPath>Объект.ИНН</DataPath>
          <Width>20</Width>
        </InputField>
        <InputField>
          <Name>КПП</Name>
          <Id>104</Id>
          <Title>КПП</Title>
          <DataPath>Объект.КПП</DataPath>
          <Width>20</Width>
        </InputField>
        <LabelDecoration>
          <Name>НадписьПримечание</Name>
          <Id>105</Id>
          <Title>Заполните все обязательные поля перед записью</Title>
          <TextColor>Style.ExplanationTextColor</TextColor>
          <HorizontalStretch>true</HorizontalStretch>
        </LabelDecoration>
        <InputField>
          <Name>Комментарий</Name>
          <Id>106</Id>
          <Title>Комментарий</Title>
          <DataPath>Объект.Комментарий</DataPath>
          <Width>60</Width>
          <Height>3</Height>
          <MultiLine>true</MultiLine>
          <HorizontalStretch>true</HorizontalStretch>
        </InputField>
        <CheckBoxField>
          <Name>Пометка</Name>
          <Id>107</Id>
          <Title>Пометка удаления</Title>
          <DataPath>Объект.ПометкаУдаления</DataPath>
        </CheckBoxField>
        <InputField>
          <Name>ДатаДокумента</Name>
          <Id>108</Id>
          <Title>Дата</Title>
          <DataPath>ДатаДокумента</DataPath>
          <Width>15</Width>
        </InputField>
      </Elements>
    </UsualGroup>
    <Button>
      <Name>КнопкаЗаписать</Name>
      <Id>200</Id>
      <Title>Записать</Title>
      <CommandName>Записать</CommandName>
      <Representation>Auto</Representation>
      <DefaultButton>true</DefaultButton>
    </Button>
    <Button>
      <Name>КнопкаЗакрыть</Name>
      <Id>201</Id>
      <Title>Закрыть</Title>
      <CommandName>Закрыть</CommandName>
    </Button>
  </Elements>
  <Commands>
    <Command>
      <Name>Записать</Name>
      <Id>300</Id>
      <Title>Записать</Title>
      <ToolTip>Записать и закрыть</ToolTip>
      <Action>Записать</Action>
    </Command>
    <Command>
      <Name>Закрыть</Name>
      <Id>301</Id>
      <Title>Закрыть</Title>
      <Action>Закрыть</Action>
    </Command>
  </Commands>
</ManagedForm>
